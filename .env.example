PORT=8787
DEFAULT_COMPANY=ROKA
DEFAULT_AI_PROVIDER=openai

# LiveKit realtime transport. Tambien configurable desde la UI y /api/config.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_AGENT_NAME=

# Proveedores IA/avatar. El usuario final puede capturar llaves/modelos desde la UI.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-realtime

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-live-001

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE=

HEYGEN_API_KEY=
HEYGEN_AVATAR=

D_ID_API_KEY=
D_ID_AGENT=

# Telemarketing Twilio
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_TWIML_APP_SID=
TWILIO_PHONE_NUMBER=
TWILIO_WEBHOOK_AUTH_TOKEN=
TWILIO_CALLER_NAME=ROKA Agente

# CRM bridge (ROKA-CRM agencyCrmBridge)
CRM_BRIDGE_URL=
CRM_BRIDGE_TOKEN=
CRM_ORGANIZATION_ID=
CRM_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8787

# Messaging channels
WHATSAPP_PROVIDER=twilio
WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# Firebase Auth (ROKA-CRM)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
